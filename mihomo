full_setup() {
  require_root
  ensure_layout
  ensure_permissions
  load_settings
  if [[ ! -x "$MIHOMO_BIN" ]]; then
    install_binary "${CORE_CHANNEL:-alpha}"
  fi
  render_config
  write_service
  write_sysctl
  [[ -f "$COUNTRY_MMDB" ]] || install_country_mmdb
  ensure_geosite_ready
  install_webui zashboard
  configure_restart_timer "${RESTART_INTERVAL_HOURS:-0}"
  configure_alpha_update "${ALPHA_AUTO_UPDATE:-0}" "${ALPHA_UPDATE_ONCALENDAR:-daily}"
  config_test
  if [[ "$(node_enabled_count)" -gt 0 ]]; then
    systemctl_cmd enable --now mihomo
    ok "部署完成并已启动"
  else
    systemctl_cmd disable --now mihomo >/dev/null 2>&1 || true
    warn "部署已完成，但当前没有启用中的节点，未启动 mihomo。导入并启用节点后执行: mihomo start"
  fi
}

install_self() {
  require_root
  install_project "$SOURCE_ROOT"
}

press_enter() {
  [[ -t 0 && -t 1 ]] || return 0
  read -rp "按回车继续..." _
}

interactive_menu() {
  require_root
  while true; do
    clear 2>/dev/null || true
    show_status
    echo
    echo "1) 初始化/修复部署"
    echo "2) 节点管理"
    echo "3) 配置旁路由入口与容器直连"
    echo "4) 服务管理"
    echo "5) 健康检查"
    echo "6) 运行审计"
    echo "7) 日志与诊断"
    echo "8) 高级维护（少用）"
    echo "0) 退出"
    echo
    read -rp "请选择 [0-8]: " action
    case "$action" in
      1) full_setup; press_enter ;;
      2) nodes_menu; press_enter ;;
      3) router_wizard; press_enter ;;
      4) service_menu; press_enter ;;
      5) healthcheck; press_enter ;;
      6) runtime_audit; press_enter ;;
      7) diagnostics_menu; press_enter ;;
      8) advanced_menu ;;
      0) break ;;
      *) warn "无效选择"; press_enter ;;
    esac
  done
}

usage() {
  cat <<EOF
mihomo v${SCRIPT_VERSION}

核心命令:
  $0
  $0 menu
  $0 setup
  $0 status
  $0 show-secret
  $0 start | restart | stop
  $0 enable-start | enable
  $0 import-links
  $0 nodes
  $0 rename-node
  $0 toggle-node
  $0 router-wizard
  $0 healthcheck
  $0 runtime-audit
  $0 diagnose
  $0 logs

进阶配置:
  $0 rules
  $0 add-rule
  $0 remove-rule
  $0 set-mode [rule|global|direct]
  $0 set-ports
  $0 install-geosite
  $0 test-config
  $0 audit-installation

维护与内部命令:
  $0 update-alpha [--quiet]
  $0 update-stable [--quiet]
  $0 rollback-core
  $0 install-webui
  $0 configure-restart [hours]
  $0 configure-alpha-update [0|1] [OnCalendar]
  $0 sync-rules-repo
  $0 configure-rules-sync [0|1] [repo_dir]
  $0 render-config
  $0 apply-rules
  $0 clear-rules
  $0 install-self
EOF
}

main() {
  case "${1:-}" in
    "")
      if [[ -t 0 && -t 1 ]]; then
        interactive_menu
      else
        usage
      fi
      ;;
    menu) interactive_menu ;;
    setup|bootstrap) full_setup ;;
    install-self) install_self ;;
    import-links) import_links ;;
    nodes) list_nodes_pretty ;;
    rename-node) rename_node ;;
    toggle-node) toggle_node ;;
    rules) list_rules_pretty ;;
    add-rule) add_custom_rule ;;
    remove-rule) remove_custom_rule ;;
    set-mode) set_mode "${2:-rule}" ;;
    router-wizard) router_wizard ;;
    set-ports) configure_ports ;;
    install-geosite|update-geosite) install_geosite_dat ;;
    update-alpha)
      install_binary alpha "${2:-}"
      upsert_env_var "$SETTINGS_ENV" "CORE_CHANNEL" "alpha"
      restart_service_if_active
      ;;
    update-stable)
      install_binary stable "${2:-}"
      upsert_env_var "$SETTINGS_ENV" "CORE_CHANNEL" "stable"
      restart_service_if_active
      ;;
    rollback-core) rollback_core ;;
    install-webui) install_webui zashboard; restart_service_if_active ;;
    start) start_service_command ;;
    restart) restart_service_command ;;
    stop) stop_service_command ;;
    enable-start) enable_and_start_service_command ;;
    enable) enable_service_command ;;
    configure-restart)
      if [[ -n "${2:-}" ]]; then
        configure_restart_timer "$2"
      else
        configure_restart_menu
      fi
      ;;
    configure-alpha-update)
      if [[ -n "${2:-}" ]]; then
        configure_alpha_update "$2" "${3:-daily}"
      else
        configure_alpha_update_menu
      fi
      ;;
    sync-rules-repo) sync_rules_repo ;;
    configure-rules-sync)
      if [[ -n "${2:-}" ]]; then
        upsert_env_var "$SETTINGS_ENV" "RULES_AUTO_SYNC" "$2"
        upsert_env_var "$SETTINGS_ENV" "RULES_REPO_DIR" "${3:-/root/mihomo-rules}"
        ok "规则仓库同步设置已更新"
      else
        configure_rules_sync_menu
      fi
      ;;
    render-config) render_config ;;
    test-config) config_test ;;
    healthcheck) healthcheck ;;
    audit-installation) audit_installation ;;
    diagnose) diagnose ;;
    runtime-audit|soak-report) runtime_audit ;;
    logs) journalctl_cmd -u mihomo -n 100 --no-pager ;;
    apply-rules) apply_rules ;;
    clear-rules) clear_rules ;;
    status) show_status ;;
    show-secret|controller-secret) show_secret_command ;;
    -h|--help|help) usage ;;
    *) die "未知命令: $1" ;;
  esac
}

main "$@"
