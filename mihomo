#!/usr/bin/env bash

set -euo pipefail

SOURCE_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
APP_ROOT="${APP_ROOT:-$SOURCE_ROOT}"
SCRIPT_VERSION="0.6.0"

# shellcheck disable=SC1091
source "${APP_ROOT}/lib/common.sh"
# shellcheck disable=SC1091
source "${APP_ROOT}/lib/render.sh"

snapshot_before_change() {
  snapshot_current_state "${1:-change}" >/dev/null 2>&1 || true
}

list_nodes_pretty() {
  local total=0
  while IFS=$'\t' read -r _ _ _ _ _ _ _ _ _; do
    total=$((total + 1))
  done < <(node_list_tsv || true)
  if [[ "$total" -eq 0 ]]; then
    echo "暂无节点"
    return 0
  fi
  printf '%-4s %-6s %-28s %-22s %-6s %-10s %-10s %-16s\n' "ID" "状态" "名称" "地址" "端口" "网络" "安全" "来源"
  local source_label
  while IFS=$'\t' read -r idx enabled name server port network security _id source; do
    source_label="${source:-manual}"
    if [[ "$source_label" == subscription:* ]]; then
      source_label="subscription(ro):${source_label#subscription:}"
    fi
    printf '%-4s %-6s %-28s %-22s %-6s %-10s %-10s %-16s\n' \
      "$idx" \
      "$([[ "$enabled" == "1" ]] && printf '启用' || printf '关闭')" \
      "$name" "$server" "$port" "$network" "$security" "$source_label"
  done < <(node_list_tsv)
}

list_rules_pretty_from_file() {
  local state_file="$1"
  local title="$2"
  if [[ ! -s "$state_file" ]]; then
    echo "暂无${title}"
    return 0
  fi
  printf '%-4s %s\n' "ID" "规则"
  while IFS=$'\t' read -r idx rule; do
    printf '%-4s %s\n' "$idx" "$rule"
  done < <(python3 "$STATECTL" list-rules "$state_file")
}

list_custom_rules_pretty() {
  list_rules_pretty_from_file "$RULES_STATE_FILE" "自定义规则"
}

list_acl_pretty() {
  list_rules_pretty_from_file "$ACL_STATE_FILE" "ACL 规则"
}

list_subscriptions_pretty() {
  local counts
  counts="$(subscription_counts)"
  echo "订阅: 启用 ${counts%%$'\t'*} / 总计 ${counts##*$'\t'}"
  if [[ "${counts##*$'\t'}" == "0" ]]; then
    echo "暂无订阅"
    return 0
  fi
  printf '%-4s %-8s %-20s %-6s %-8s %-10s %-24s %s\n' "ID" "内部ID" "名称" "启用" "缓存" "可枚举" "缓存成功" "URL"
  while IFS=$'\t' read -r idx sub_id name url enabled last_success enumerated_count last_error; do
    printf '%-4s %-8s %-20s %-6s %-8s %-10s %-24s %s\n' \
      "$idx" "${sub_id:0:8}" "$name" \
      "$([[ "$enabled" == "1" ]] && printf '启用' || printf '关闭')" \
      "$([[ -s "$(subscription_provider_file "$sub_id")" ]] && printf '就绪' || printf '缺失')" \
      "$enumerated_count" "${last_success:-未成功}" "$url"
    if [[ -n "$last_error" ]]; then
      printf '     错误: %s\n' "$last_error"
    fi
  done < <(subscription_list_tsv)
  return 0
}

resolve_subscription_id_from_index() {
  local index="$1"
  local idx
  local sub_id
  while IFS=$'\t' read -r idx sub_id _ _ _ _ _ _; do
    if [[ "$idx" == "$index" ]]; then
      printf '%s\n' "$sub_id"
      return 0
    fi
  done < <(subscription_list_tsv)
  return 1
}

post_state_change() {
  render_config
  config_test
  restart_service_if_active
}

choose_rule_target() {
  printf '%s\n' "1) DIRECT" >&2
  printf '%s\n' "2) PROXY" >&2
  printf '%s\n' "3) REJECT" >&2
  printf '%s\n' "4) AUTO" >&2
  printf '%s\n' "5) 指定启用节点" >&2
  local target_choice
  read -rp "目标 [1-5]: " target_choice >&2
  case "$target_choice" in
    1) printf 'DIRECT' ;;
    2) printf 'PROXY' ;;
    3) printf 'REJECT' ;;
    4) printf 'AUTO' ;;
    5)
      local names
      names="$(node_enabled_names || true)"
      [[ -n "$names" ]] || die "当前没有启用中的节点"
      printf '%s\n' "$names" >&2
      local node_name
      read -rp "输入目标节点名称: " node_name >&2
      [[ -n "$node_name" ]] || die "节点名称不能为空"
      printf '%s' "$node_name"
      ;;
    *) die "无效目标" ;;
  esac
}

choose_custom_rule_kind() {
  echo "1) 精确域名 DOMAIN"
  echo "2) 域名后缀 DOMAIN-SUFFIX"
  echo "3) 关键字 DOMAIN-KEYWORD"
  local kind_choice
  read -rp "规则类型 [1/2/3]: " kind_choice
  case "$kind_choice" in
    1) printf 'domain\n' ;;
    2) printf 'suffix\n' ;;
    3) printf 'keyword\n' ;;
    *) die "无效规则类型" ;;
  esac
}

choose_acl_rule_kind() {
  echo "1) DOMAIN"
  echo "2) DOMAIN-SUFFIX"
  echo "3) DOMAIN-KEYWORD"
  echo "4) SRC-IP-CIDR"
  echo "5) IP-CIDR"
  echo "6) DST-PORT"
  echo "7) GEOIP"
  echo "8) GEOSITE"
  echo "9) RULE-SET"
  local kind_choice
  read -rp "ACL 类型 [1-9]: " kind_choice
  case "$kind_choice" in
    1) printf 'domain\n' ;;
    2) printf 'suffix\n' ;;
    3) printf 'keyword\n' ;;
    4) printf 'src-cidr\n' ;;
    5) printf 'ip-cidr\n' ;;
    6) printf 'port\n' ;;
    7) printf 'geoip\n' ;;
    8) printf 'geosite\n' ;;
    9) printf 'ruleset\n' ;;
    *) die "无效 ACL 类型" ;;
  esac
}

import_links() {
  require_root
  require_statectl
  ensure_layout

  local tmp
  local scan_tmp
  local line
  local normalized_line
  local lowered_line
  local uri
  local default_name
  local server
  local port
  local network
  local security
  local supported
  local scheme
  local reason
  local custom_name
  local enabled_answer
  local enabled_value
  local imported=0
  local skipped=0
  local input_tty="/dev/tty"

  [[ -r "$input_tty" ]] || input_tty="/dev/stdin"
  tmp="$(mktemp)"
  scan_tmp="$(mktemp)"
  info "请粘贴节点链接，每行一个。输入 end 结束，也可以按 Ctrl-D 结束。"
  while IFS= read -r line <"$input_tty"; do
    normalized_line="${line%$'\r'}"
    lowered_line="${normalized_line,,}"
    [[ -z "$normalized_line" ]] && continue
    [[ "$lowered_line" == "end" || "$lowered_line" == "done" ]] && break
    printf '%s\n' "$normalized_line" >>"$tmp"
  done

  python3 "$STATECTL" scan-uris "$tmp" >"$scan_tmp"
  snapshot_before_change "import-links"

  while IFS=$'\t' read -r uri default_name server port network security supported scheme reason; do
    [[ -n "$uri" ]] || continue
    if [[ "$supported" != "1" ]]; then
      warn "跳过不支持的 ${scheme:-unknown} 节点: ${default_name:-$uri}"
      [[ -n "$reason" ]] && warn "原因: ${reason}"
      skipped=$((skipped + 1))
      continue
    fi
    echo
    echo "节点: ${server}:${port}  ${network}/${security} (${scheme})"
    read -r -p "名称 [${default_name}]: " custom_name <"$input_tty"
    custom_name="${custom_name:-$default_name}"
    read -r -p "立即启用? [Y/n]: " enabled_answer <"$input_tty"
    if [[ "${enabled_answer,,}" == "n" ]]; then
      enabled_value="0"
    else
      enabled_value="1"
    fi
    python3 "$STATECTL" append-node "$NODES_STATE_FILE" "$uri" "$custom_name" "$enabled_value" >/dev/null
    imported=$((imported + 1))
  done <"$scan_tmp"

  rm -f "$tmp" "$scan_tmp"
  [[ "$imported" -gt 0 ]] || die "没有读取到有效节点"
  post_state_change
  ok "已处理 ${imported} 条节点"
  [[ "$skipped" -gt 0 ]] && warn "有 ${skipped} 条链接因协议不受支持而被跳过"
}

rename_node() {
  require_root
  require_statectl
  list_nodes_pretty
  local idx
  local new_name
  read -rp "输入要改名的节点 ID: " idx
  read -rp "新的名称: " new_name
  [[ -n "$new_name" ]] || die "名称不能为空"
  snapshot_before_change "rename-node"
  python3 "$STATECTL" rename-node "$NODES_STATE_FILE" "$idx" "$new_name" "$RULES_STATE_FILE" "$ACL_STATE_FILE" --exclude-source-kind subscription
  post_state_change
  ok "节点已重命名"
}

toggle_node() {
  require_root
  require_statectl
  list_nodes_pretty
  local idx
  local enabled
  read -rp "输入节点 ID: " idx
  read -rp "启用填 1，关闭填 0: " enabled
  [[ "$enabled" == "1" || "$enabled" == "0" ]] || die "只能填 1 或 0"
  snapshot_before_change "toggle-node"
  python3 "$STATECTL" set-node-enabled "$NODES_STATE_FILE" "$idx" "$enabled" --exclude-source-kind subscription
  post_state_change
  ok "节点状态已更新"
}

add_rule_interactive() {
  local state_file="$1"
  local kind
  local pattern
  local target
  kind="$2"
  [[ -n "$kind" ]] || kind="$(choose_custom_rule_kind)"
  if [[ -n "${3:-}" ]]; then
    pattern="$3"
  else
    read -rp "输入规则内容: " pattern
  fi
  [[ -n "$pattern" ]] || die "规则内容不能为空"
  if [[ -n "${4:-}" ]]; then
    target="$4"
  else
    target="$(choose_rule_target)"
  fi
  python3 "$STATECTL" add-rule "$state_file" "$kind" "$pattern" "$target"
}

add_custom_rule() {
  require_root
  snapshot_before_change "add-rule"
  add_rule_interactive "$RULES_STATE_FILE" "${1:-}" "${2:-}" "${3:-}"
  post_state_change
  ok "自定义规则已添加"
}

remove_custom_rule() {
  require_root
  local idx="${1:-}"
  list_custom_rules_pretty
  [[ -n "$idx" ]] || read -rp "输入要删除的规则 ID: " idx
  snapshot_before_change "remove-rule"
  python3 "$STATECTL" remove-rule "$RULES_STATE_FILE" "$idx"
  post_state_change
  ok "自定义规则已删除"
}

add_acl_rule() {
  require_root
  local kind="${1:-}"
  local pattern="${2:-}"
  local target="${3:-}"
  snapshot_before_change "add-acl"
  [[ -n "$kind" ]] || kind="$(choose_acl_rule_kind)"
  [[ -n "$pattern" ]] || read -rp "输入 ACL 内容: " pattern
  [[ -n "$pattern" ]] || die "ACL 内容不能为空"
  [[ -n "$target" ]] || target="$(choose_rule_target)"
  python3 "$STATECTL" add-rule "$ACL_STATE_FILE" "$kind" "$pattern" "$target"
  post_state_change
  ok "ACL 规则已添加"
}

remove_acl_rule() {
  require_root
  local idx="${1:-}"
  list_acl_pretty
  [[ -n "$idx" ]] || read -rp "输入要删除的 ACL 规则 ID: " idx
  snapshot_before_change "remove-acl"
  python3 "$STATECTL" remove-rule "$ACL_STATE_FILE" "$idx"
  post_state_change
  ok "ACL 规则已删除"
}

add_subscription_command() {
  require_root
  require_statectl
  local name="${1:-}"
  local url="${2:-}"
  local enabled="${3:-1}"
  [[ -n "$name" ]] || read -rp "订阅名称: " name
  [[ -n "$url" ]] || read -rp "订阅 URL: " url
  [[ -n "$name" && -n "$url" ]] || die "订阅名称和 URL 不能为空"
  [[ "$enabled" == "0" || "$enabled" == "1" ]] || enabled="1"
  snapshot_before_change "add-subscription"
  python3 "$STATECTL" append-subscription "$SUBSCRIPTIONS_STATE_FILE" "$name" "$url" "$enabled" >/dev/null
  ok "订阅已添加"
}

toggle_subscription_command() {
  require_root
  require_statectl
  list_subscriptions_pretty
  local idx
  local enabled
  local sub_id
  read -rp "输入订阅 ID: " idx
  read -rp "启用填 1，关闭填 0: " enabled
  [[ "$enabled" == "1" || "$enabled" == "0" ]] || die "只能填 1 或 0"
  sub_id="$(resolve_subscription_id_from_index "$idx")" || die "订阅不存在"
  snapshot_before_change "toggle-subscription"
  python3 "$STATECTL" set-subscription-enabled "$SUBSCRIPTIONS_STATE_FILE" "$sub_id" "$enabled"
  if [[ "$enabled" == "0" ]]; then
    python3 "$STATECTL" purge-subscription-nodes "$NODES_STATE_FILE" "$sub_id" >/dev/null
  fi
  post_state_change
  if [[ "$enabled" == "1" && ! -s "$(subscription_provider_file "$sub_id")" ]]; then
    warn "订阅已启用，但当前还没有 provider 缓存；执行 mihomo update-subscriptions 拉取后才会生效。"
  fi
  ok "订阅状态已更新"
}

remove_subscription_command() {
  require_root
  require_statectl
  list_subscriptions_pretty
  local idx
  local sub_id
  read -rp "输入要删除的订阅 ID: " idx
  sub_id="$(resolve_subscription_id_from_index "$idx")" || die "订阅不存在"
  snapshot_before_change "remove-subscription"
  python3 "$STATECTL" purge-subscription-nodes "$NODES_STATE_FILE" "$sub_id" >/dev/null
  rm -f "$(subscription_provider_file "$sub_id")"
  python3 "$STATECTL" remove-subscription "$SUBSCRIPTIONS_STATE_FILE" "$sub_id"
  post_state_change
  ok "订阅已删除"
}

update_subscriptions_command() {
  require_root
  require_statectl
  ensure_layout
  local tmp
  local updated=0
  local failed=0
  local idx
  local sub_id
  local name
  local url
  local enabled
  local last_success
  local enumerated_count
  local last_error
  local provider_file
  snapshot_before_change "update-subscriptions"
  while IFS=$'\t' read -r idx sub_id name url enabled last_success enumerated_count last_error; do
    [[ "$enabled" == "1" ]] || continue
    tmp="$(mktemp)"
    if curl_cmd -fsSL "$url" -o "$tmp"; then
      provider_file="$(subscription_provider_file "$sub_id")"
      install -D -m 0640 "$tmp" "$provider_file"
      chown root:"$MIHOMO_USER" "$provider_file"
      enumerated_count="$(python3 "$STATECTL" count-supported-uris "$tmp")"
      python3 "$STATECTL" mark-subscription-success "$SUBSCRIPTIONS_STATE_FILE" "$sub_id" "$enumerated_count" >/dev/null
      ok "订阅 provider 缓存已更新: ${name} (可枚举 ${enumerated_count} 节点)"
      updated=$((updated + 1))
    else
      python3 "$STATECTL" mark-subscription-error "$SUBSCRIPTIONS_STATE_FILE" "$sub_id" "curl failed for ${url}" >/dev/null
      warn "订阅更新失败: ${name}"
      failed=$((failed + 1))
    fi
    rm -f "$tmp"
  done < <(subscription_list_tsv)

  if [[ "$updated" -gt 0 ]]; then
    post_state_change
  fi
  if [[ "$updated" -eq 0 && "$failed" -eq 0 ]]; then
    warn "没有启用中的订阅"
    return 0
  fi
  [[ "$failed" -eq 0 ]] || return 1
}

list_templates_command() {
  load_settings_readonly
  load_router_env_readonly
  local current="${TEMPLATE_NAME:-$PROFILE_TEMPLATE}"
  for template_name in nas-single-lan-v4 nas-single-lan-dualstack nas-multi-bridge nas-explicit-proxy-only; do
    printf '%s%s - %s\n' "$([[ "$current" == "$template_name" ]] && printf '* ' || printf '  ')" "$template_name" "$(template_summary "$template_name")"
  done
}

list_rule_presets_command() {
  load_settings_readonly
  local current="${RULESET_PRESET:-$(default_rule_preset)}"
  printf '%s%s - %s\n' "$([[ "$current" == "default" ]] && printf '* ' || printf '  ')" "default" "$(rule_preset_summary default)"
}

show_rules_repo_command() {
  load_settings_readonly
  require_rulepresetctl
  local preset_name="${RULESET_PRESET:-$(default_rule_preset)}"
  local manifest_path
  manifest_path="$(rule_preset_manifest_path "$preset_name" 2>/dev/null || true)"
  [[ -n "$manifest_path" && -f "$manifest_path" ]] || die "未找到规则仓库清单: ${preset_name}"
  python3 "$RULEPRESETCTL" describe "$manifest_path"
}

search_rules_repo_entries_command() {
  load_settings_readonly
  require_rulepresetctl
  local keyword="${1:-}"
  [[ -n "$keyword" ]] || die "用法: mihomo rules-repo-find [keyword]"
  local manifest_path
  manifest_path="$(rule_preset_manifest_path "${RULESET_PRESET:-$(default_rule_preset)}" 2>/dev/null || true)"
  [[ -n "$manifest_path" && -f "$manifest_path" ]] || die "未找到规则仓库清单"
  python3 "$RULEPRESETCTL" search-entries "$manifest_path" "$keyword"
}

print_ruleset_brief() {
  load_settings_readonly
  require_rulepresetctl
  local ruleset_name="$1"
  local manifest_path
  manifest_path="$(rule_preset_manifest_path "${RULESET_PRESET:-$(default_rule_preset)}" 2>/dev/null || true)"
  [[ -n "$manifest_path" && -f "$manifest_path" ]] || die "未找到规则仓库清单"
  python3 "$RULEPRESETCTL" describe-ruleset "$manifest_path" "$ruleset_name"
}

list_rules_repo_entries_command() {
  load_settings_readonly
  require_rulepresetctl
  local ruleset_name="${1:-}"
  local keyword="${2:-}"
  [[ -n "$ruleset_name" ]] || die "用法: mihomo rules-repo-entries [ruleset] [keyword]"
  local manifest_path
  manifest_path="$(rule_preset_manifest_path "${RULESET_PRESET:-$(default_rule_preset)}" 2>/dev/null || true)"
  [[ -n "$manifest_path" && -f "$manifest_path" ]] || die "未找到规则仓库清单"
  if [[ -n "$keyword" ]]; then
    python3 "$RULEPRESETCTL" list-entries "$manifest_path" "$ruleset_name" "$keyword"
  else
    python3 "$RULEPRESETCTL" list-entries "$manifest_path" "$ruleset_name"
  fi
}

add_rules_repo_entry_command() {
  require_root
  load_settings
  load_router_env
  local ruleset_name="${1:-}"
  local value="${2:-}"
  [[ -n "$ruleset_name" ]] || die "用法: mihomo add-repo-rule [ruleset] [value]"
  if [[ -z "$value" ]]; then
    print_ruleset_brief "$ruleset_name"
    read -rp "规则内容: " value
  fi
  [[ -n "$value" ]] || die "规则内容不能为空"
  local manifest_path
  manifest_path="$(rule_preset_manifest_path "${RULESET_PRESET:-$(default_rule_preset)}" 2>/dev/null || true)"
  [[ -n "$manifest_path" && -f "$manifest_path" ]] || die "未找到规则仓库清单"
  snapshot_before_change "add-repo-rule"
  python3 "$RULEPRESETCTL" append-entry "$manifest_path" "$ruleset_name" "$value"
  post_state_change
  ok "项目规则仓库已添加规则: ${ruleset_name} -> ${value}"
}

remove_rules_repo_entry_command() {
  require_root
  load_settings
  load_router_env
  local ruleset_name="${1:-}"
  local value="${2:-}"
  [[ -n "$ruleset_name" ]] || die "用法: mihomo remove-repo-rule [ruleset] [value]"
  if [[ -z "$value" ]]; then
    print_ruleset_brief "$ruleset_name"
    read -rp "规则内容: " value
  fi
  [[ -n "$value" ]] || die "规则内容不能为空"
  local manifest_path
  manifest_path="$(rule_preset_manifest_path "${RULESET_PRESET:-$(default_rule_preset)}" 2>/dev/null || true)"
  [[ -n "$manifest_path" && -f "$manifest_path" ]] || die "未找到规则仓库清单"
  snapshot_before_change "remove-repo-rule"
  python3 "$RULEPRESETCTL" remove-entry "$manifest_path" "$ruleset_name" "$value"
  post_state_change
  ok "项目规则仓库已删除规则: ${ruleset_name} -> ${value}"
}

remove_rules_repo_entry_by_index_command() {
  require_root
  load_settings
  load_router_env
  local ruleset_name="${1:-}"
  local index="${2:-}"
  [[ -n "$ruleset_name" ]] || die "用法: mihomo remove-repo-rule-index [ruleset] [index]"
  if [[ -z "$index" ]]; then
    print_ruleset_brief "$ruleset_name"
    list_rules_repo_entries_command "$ruleset_name"
    read -rp "要删除的序号: " index
  fi
  [[ "$index" =~ ^[0-9]+$ ]] || die "序号必须是正整数"
  local manifest_path
  manifest_path="$(rule_preset_manifest_path "${RULESET_PRESET:-$(default_rule_preset)}" 2>/dev/null || true)"
  [[ -n "$manifest_path" && -f "$manifest_path" ]] || die "未找到规则仓库清单"
  snapshot_before_change "remove-repo-rule-index"
  python3 "$RULEPRESETCTL" remove-entry-index "$manifest_path" "$ruleset_name" "$index"
  post_state_change
  ok "项目规则仓库已按序号删除规则: ${ruleset_name} #${index}"
}

set_template_command() {
  require_root
  local template_name="${1:-}"
  if [[ -z "$template_name" ]]; then
    echo "1) nas-single-lan-v4"
    echo "2) nas-single-lan-dualstack (兼容保留，不建议使用)"
    echo "3) nas-multi-bridge"
    echo "4) nas-explicit-proxy-only"
    read -rp "模板 [1-4]: " template_name
    case "$template_name" in
      1) template_name="nas-single-lan-v4" ;;
      2) template_name="nas-single-lan-dualstack" ;;
      3) template_name="nas-multi-bridge" ;;
      4) template_name="nas-explicit-proxy-only" ;;
      *) die "无效模板" ;;
    esac
  fi
  template_exists "$template_name" || die "未知模板: ${template_name}"
  if template_is_deprecated "$template_name"; then
    warn "nas-single-lan-dualstack 当前仅兼容保留；项目不再把它视为真双栈旁路由模板。"
  fi
  snapshot_before_change "set-template"
  upsert_env_var "$SETTINGS_ENV" "PROFILE_TEMPLATE" "$template_name"
  write_router_env_from_template "$template_name"
  post_state_change
  ok "模板已切换为 ${template_name}"
}

set_rule_preset_command() {
  require_root
  load_settings
  local preset_name="${1:-}"
  if [[ -z "$preset_name" ]]; then
    echo "1) default"
    read -rp "规则预设 [1]: " preset_name
    case "$preset_name" in
      1) preset_name="default" ;;
      *) die "无效规则预设" ;;
    esac
  fi
  rule_preset_exists "$preset_name" || die "未知规则预设: ${preset_name}"
