usage() {
  cat <<EOF
mihomo v${SCRIPT_VERSION}

核心命令:
  $0
  $0 menu
  $0 setup
  $0 repair
  $0 status
  $0 show-secret
  $0 start | restart | stop
  $0 enable-start | enable
  $0 import-links
  $0 nodes
  $0 subscriptions
  $0 add-subscription [name] [url] [enabled]
  $0 update-subscriptions
  $0 templates
  $0 set-template [name]
  $0 rule-presets
  $0 set-rule-preset [name]
  $0 rules-repo
  $0 rules-repo-entries [ruleset] [keyword]
  $0 rules-repo-find [keyword]
  $0 add-repo-rule [ruleset] [value]
  $0 remove-repo-rule [ruleset] [value]
  $0 remove-repo-rule-index [ruleset] [index]
  $0 apply-default-template
  $0 router-wizard
  $0 acl
  $0 add-acl [kind] [pattern] [target]
  $0 remove-acl [index]
  $0 healthcheck
  $0 runtime-audit
  $0 diagnose
  $0 rollback-config
  $0 logs

兼容命令:
  $0 rules
  $0 add-rule [kind] [pattern] [target]
  $0 remove-rule [index]
  $0 rename-node
  $0 toggle-node

维护与内部命令:
  $0 update-alpha [--quiet]
  $0 update-stable [--quiet]
  $0 rollback-core
  $0 install-webui [name] [url]
  $0 install-geosite
  $0 set-mode [rule|global|direct]
  $0 set-ports
  $0 configure-restart [hours]
  $0 configure-alpha-update [0|1] [OnCalendar]
  $0 render-config
  $0 test-config
  $0 audit-installation
  $0 apply-rules
  $0 clear-rules
  $0 install-self
  $0 install-self-sync [minutes]
  $0 disable-self-sync
EOF
}

main() {
  case "${1:-}" in
    "")
      if [[ -t 0 && -t 1 ]]; then
        interactive_menu
      else
        usage
      fi
      ;;
    menu) interactive_menu ;;
    setup|bootstrap) full_setup ;;
    repair) repair_command ;;
    install-self) install_self ;;
    install-self-sync) install_self_sync "${2:-1}" ;;
    disable-self-sync) disable_self_sync ;;
    import-links) import_links ;;
    nodes) list_nodes_pretty ;;
    subscriptions) list_subscriptions_pretty ;;
    add-subscription) add_subscription_command "${2:-}" "${3:-}" "${4:-1}" ;;
    update-subscriptions) update_subscriptions_command ;;
    templates) list_templates_command ;;
    set-template) set_template_command "${2:-}" ;;
    rule-presets) list_rule_presets_command ;;
    set-rule-preset) set_rule_preset_command "${2:-}" ;;
    rules-repo) show_rules_repo_command ;;
    rules-repo-entries) list_rules_repo_entries_command "${2:-}" "${3:-}" ;;
    rules-repo-find) search_rules_repo_entries_command "${2:-}" ;;
    add-repo-rule) add_rules_repo_entry_command "${2:-}" "${3:-}" ;;
    remove-repo-rule) remove_rules_repo_entry_command "${2:-}" "${3:-}" ;;
    remove-repo-rule-index) remove_rules_repo_entry_by_index_command "${2:-}" "${3:-}" ;;
    apply-default-template|apply-self-use) apply_default_template_command ;;
    rename-node) rename_node ;;
    toggle-node) toggle_node ;;
    acl) list_acl_pretty ;;
    add-acl) add_acl_rule "${2:-}" "${3:-}" "${4:-}" ;;
    remove-acl) remove_acl_rule "${2:-}" ;;
    rules) list_custom_rules_pretty ;;
    add-rule) add_custom_rule "${2:-}" "${3:-}" "${4:-}" ;;
    remove-rule) remove_custom_rule "${2:-}" ;;
    set-mode) set_mode "${2:-rule}" ;;
    router-wizard) router_wizard ;;
    set-ports) snapshot_before_change "set-ports"; configure_ports ;;
    install-geosite|update-geosite) install_geosite_dat ;;
    update-alpha)
      snapshot_before_change "update-alpha"
      install_binary alpha "${2:-}"
      upsert_env_var "$SETTINGS_ENV" "CORE_CHANNEL" "alpha"
      restart_service_if_active
      ;;
    update-stable)
      snapshot_before_change "update-stable"
      install_binary stable "${2:-}"
      upsert_env_var "$SETTINGS_ENV" "CORE_CHANNEL" "stable"
      restart_service_if_active
      ;;
    rollback-core) rollback_core ;;
    install-webui) install_webui "${2:-}" "${3:-}" ;;
    start) start_service_command ;;
    restart) restart_service_command ;;
    stop) stop_service_command ;;
    enable-start) enable_and_start_service_command ;;
    enable) enable_service_command ;;
    configure-restart)
      if [[ -n "${2:-}" ]]; then
        snapshot_before_change "configure-restart"
        configure_restart_timer "$2"
      else
        configure_restart_menu
      fi
      ;;
    configure-alpha-update)
      if [[ -n "${2:-}" ]]; then
        snapshot_before_change "configure-alpha-update"
        configure_alpha_update "$2" "${3:-daily}"
      else
        configure_alpha_update_menu
      fi
      ;;
    render-config) render_config ;;
    test-config) config_test ;;
    healthcheck) healthcheck ;;
    audit-installation) audit_installation ;;
    diagnose) diagnose ;;
    runtime-audit|soak-report) runtime_audit ;;
    logs) journalctl_cmd -u mihomo -n 100 --no-pager ;;
    rollback-config) rollback_config_command ;;
    apply-rules) apply_rules ;;
    clear-rules) clear_rules ;;
    status) show_status ;;
    show-secret|controller-secret) show_secret_command ;;
    -h|--help|help) usage ;;
    *) die "未知命令: $1" ;;
  esac
}

main "$@"
