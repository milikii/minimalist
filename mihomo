#!/usr/bin/env bash

set -euo pipefail

SOURCE_ROOT="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
APP_ROOT="${APP_ROOT:-$SOURCE_ROOT}"
SCRIPT_VERSION="0.5.0"

# shellcheck disable=SC1091
source "${APP_ROOT}/lib/common.sh"
# shellcheck disable=SC1091
source "${APP_ROOT}/lib/render.sh"

node_count_total() {
  local total=0
  while IFS=$'\t' read -r _ _ _ _ _ _ _ _; do
    total=$((total + 1))
  done < <(node_list_tsv || true)
  echo "$total"
}

list_nodes_pretty() {
  if [[ "$(node_count_total)" -eq 0 ]]; then
    echo "暂无节点"
    return 0
  fi
  printf '%-4s %-6s %-28s %-24s %-6s %-10s %-10s\n' "ID" "状态" "名称" "地址" "端口" "网络" "安全"
  while IFS=$'\t' read -r idx enabled name server port network security _id; do
    printf '%-4s %-6s %-28s %-24s %-6s %-10s %-10s\n' \
      "$idx" \
      "$([[ "$enabled" == "1" ]] && printf '启用' || printf '关闭')" \
      "$name" "$server" "$port" "$network" "$security"
  done < <(node_list_tsv)
}

import_links() {
  require_root
  require_statectl
  ensure_layout

  local tmp
  local scan_tmp
  local line
  local normalized_line
  local lowered_line
  local uri
  local default_name
  local server
  local port
  local network
  local security
  local custom_name
  local enabled_answer
  local enabled_value
  local imported=0
  local input_tty="/dev/tty"

  [[ -r "$input_tty" ]] || input_tty="/dev/stdin"
  tmp="$(mktemp)"
  scan_tmp="$(mktemp)"
  info "请粘贴节点链接，每行一个。输入 end 结束，也可以按 Ctrl-D 结束。"
  while IFS= read -r line <"$input_tty"; do
    normalized_line="${line%$'\r'}"
    lowered_line="${normalized_line,,}"
    [[ -z "$normalized_line" ]] && continue
    [[ "$lowered_line" == "end" || "$lowered_line" == "done" ]] && break
    printf '%s\n' "$normalized_line" >>"$tmp"
  done

  python3 "$STATECTL" scan-uris "$tmp" >"$scan_tmp"

  while IFS=$'	' read -r uri default_name server port network security; do
    [[ -n "$uri" ]] || continue
    echo
    echo "节点: ${server}:${port}  ${network}/${security}"
    read -r -p "名称 [${default_name}]: " custom_name <"$input_tty"
    custom_name="${custom_name:-$default_name}"
    read -r -p "立即启用? [Y/n]: " enabled_answer <"$input_tty"
    if [[ "${enabled_answer,,}" == "n" ]]; then
      enabled_value="0"
    else
      enabled_value="1"
    fi
    python3 "$STATECTL" append-node "$NODES_STATE_FILE" "$uri" "$custom_name" "$enabled_value" >/dev/null
    imported=$((imported + 1))
  done <"$scan_tmp"

  rm -f "$tmp" "$scan_tmp"
  [[ "$imported" -gt 0 ]] || die "没有读取到有效节点"
  render_config
  config_test
  restart_service_if_active
  ok "已处理 ${imported} 条节点"
}
rename_node() {
  require_root
  require_statectl
  list_nodes_pretty
  local idx
  local new_name
  read -rp "输入要改名的节点 ID: " idx
  read -rp "新的名称: " new_name
  [[ -n "$new_name" ]] || die "名称不能为空"
  python3 "$STATECTL" rename-node "$NODES_STATE_FILE" "$idx" "$new_name" "$RULES_STATE_FILE"
  render_config
  sync_rules_repo_if_enabled
  restart_service_if_active
  ok "节点已重命名"
}

toggle_node() {
  require_root
  require_statectl
  list_nodes_pretty
  local idx
  local enabled
  read -rp "输入节点 ID: " idx
  read -rp "启用填 1，关闭填 0: " enabled
  [[ "$enabled" == "1" || "$enabled" == "0" ]] || die "只能填 1 或 0"
  python3 "$STATECTL" set-node-enabled "$NODES_STATE_FILE" "$idx" "$enabled"
  render_config
  restart_service_if_active
  ok "节点状态已更新"
}

list_rules_pretty() {
  if [[ ! -s "$RULES_STATE_FILE" ]]; then
    echo "暂无自定义规则"
    return 0
  fi
  printf '%-4s %s\n' "ID" "规则"
  while IFS=$'\t' read -r idx rule; do
    printf '%-4s %s\n' "$idx" "$rule"
  done < <(python3 "$STATECTL" list-rules "$RULES_STATE_FILE")
}

choose_rule_target() {
  printf '%s\n' "1) DIRECT" >&2
  printf '%s\n' "2) PROXY" >&2
  printf '%s\n' "3) REJECT" >&2
  printf '%s\n' "4) AUTO" >&2
  printf '%s\n' "5) 指定启用节点" >&2
  local target_choice
  read -rp "目标 [1-5]: " target_choice >&2
  case "$target_choice" in
    1) printf 'DIRECT' ;;
    2) printf 'PROXY' ;;
    3) printf 'REJECT' ;;
    4) printf 'AUTO' ;;
    5)
      local names
      names="$(node_enabled_names || true)"
      [[ -n "$names" ]] || die "当前没有启用中的节点"
      printf '%s\n' "$names" >&2
      local node_name
      read -rp "输入目标节点名称: " node_name >&2
      [[ -n "$node_name" ]] || die "节点名称不能为空"
      printf '%s' "$node_name"
      ;;
    *) die "无效目标" ;;
  esac
}

add_custom_rule() {
  require_root
  require_statectl
  local kind_choice
  local kind
  local pattern
  local target

  echo "1) 精确域名 DOMAIN"
  echo "2) 域名后缀 DOMAIN-SUFFIX"
  echo "3) 关键字 DOMAIN-KEYWORD"
  read -rp "规则类型 [1/2/3]: " kind_choice
  case "$kind_choice" in
    1) kind="domain" ;;
    2) kind="suffix" ;;
    3) kind="keyword" ;;
    *) die "无效规则类型" ;;
  esac
  read -rp "输入域名/后缀/关键字: " pattern
  [[ -n "$pattern" ]] || die "规则内容不能为空"
  target="$(choose_rule_target)"
  python3 "$STATECTL" add-rule "$RULES_STATE_FILE" "$kind" "$pattern" "$target"
  render_config
  sync_rules_repo_if_enabled
  restart_service_if_active
  ok "规则已添加"
}

remove_custom_rule() {
  require_root
  require_statectl
  list_rules_pretty
  local idx
  read -rp "输入要删除的规则 ID: " idx
  python3 "$STATECTL" remove-rule "$RULES_STATE_FILE" "$idx"
  render_config
  sync_rules_repo_if_enabled
  restart_service_if_active
  ok "规则已删除"
}

configure_rules_sync_menu() {
  load_settings
  local enabled
  local repo_dir
  read -rp "启用规则仓库自动同步? 1/0 [${RULES_AUTO_SYNC:-1}]: " enabled
  enabled="${enabled:-${RULES_AUTO_SYNC:-1}}"
  read -rp "规则仓库目录 [${RULES_REPO_DIR:-/root/mihomo-rules}]: " repo_dir
  repo_dir="${repo_dir:-${RULES_REPO_DIR:-/root/mihomo-rules}}"
  upsert_env_var "$SETTINGS_ENV" "RULES_AUTO_SYNC" "$enabled"
  upsert_env_var "$SETTINGS_ENV" "RULES_REPO_DIR" "$repo_dir"
  ok "规则仓库同步设置已更新"
}

set_mode() {
  require_root
  local mode="$1"
  case "$mode" in
    rule|global|direct) ;;
    *) die "模式仅支持 rule|global|direct" ;;
  esac
  upsert_env_var "$SETTINGS_ENV" "CONFIG_MODE" "$mode"
  render_config
  restart_service_if_active
  ok "当前模式已切换为 ${mode}"
}

router_wizard() {
  require_root
  load_router_env
  local input
  local next_ingress_ifaces
  local next_dns_ifaces
  local next_host_output
  local next_lan_cidrs

  echo
  info "当前可见 IPv4 接口:"
  ip -o -4 addr show scope global 2>/dev/null | awk '{printf "  - %s  %s\n", $2, $4}' | sort -u || true
  echo
  info "当前模型: 宿主机默认直连，局域网入口透明接管，Docker 默认直连。"
  info "只有局域网设备把网关和 DNS 指向 NAS 后，才会走旁路由。"
  echo

  read -rp "局域网旁路由入口接口 [${PROXY_INGRESS_INTERFACES}]: " input
  next_ingress_ifaces="${input:-$PROXY_INGRESS_INTERFACES}"
  upsert_env_var "$ROUTER_ENV" "LAN_INTERFACES" "$next_ingress_ifaces"
  upsert_env_var "$ROUTER_ENV" "PROXY_INGRESS_INTERFACES" "$next_ingress_ifaces"

  next_lan_cidrs="$(detect_iface_networks "$next_ingress_ifaces" || true)"
  if [[ -n "$next_lan_cidrs" ]]; then
    info "自动识别入口网段: ${next_lan_cidrs}"
    upsert_env_var "$ROUTER_ENV" "LAN_CIDRS" "$next_lan_cidrs"
  else
    warn "未能从入口接口自动识别 IPv4 网段，将保留当前 LAN_CIDRS=${LAN_CIDRS:-未设置}"
  fi

  read -rp "DNS 劫持接口 [${DNS_HIJACK_INTERFACES}]: " input
  next_dns_ifaces="${input:-$DNS_HIJACK_INTERFACES}"
  upsert_env_var "$ROUTER_ENV" "DNS_HIJACK_INTERFACES" "$next_dns_ifaces"

  read -rp "宿主机本机流量是否接管 1/0（建议 0，仅让 LAN 走透明代理） [${PROXY_HOST_OUTPUT}]: " input
  next_host_output="${input:-$PROXY_HOST_OUTPUT}"
  [[ "$next_host_output" == "0" || "$next_host_output" == "1" ]] || die "宿主机流量接管只能填 0 或 1"
  upsert_env_var "$ROUTER_ENV" "PROXY_HOST_OUTPUT" "$next_host_output"

  read -rp "PT 等容器直连，空格分隔 [${BYPASS_CONTAINER_NAMES}]: " input
  upsert_env_var "$ROUTER_ENV" "BYPASS_CONTAINER_NAMES" "${input:-$BYPASS_CONTAINER_NAMES}"
  read -rp "额外直连源网段，空格分隔 [${BYPASS_SRC_CIDRS}]: " input
  upsert_env_var "$ROUTER_ENV" "BYPASS_SRC_CIDRS" "${input:-$BYPASS_SRC_CIDRS}"
  read -rp "额外直连目标网段，空格分隔 [${BYPASS_DST_CIDRS}]: " input
  upsert_env_var "$ROUTER_ENV" "BYPASS_DST_CIDRS" "${input:-$BYPASS_DST_CIDRS}"
  read -rp "额外绕过代理的 UID/用户名，空格分隔 [${BYPASS_UIDS}]: " input
  upsert_env_var "$ROUTER_ENV" "BYPASS_UIDS" "${input:-$BYPASS_UIDS}"

  echo
  echo "新的宿主机模式: $([[ "$next_host_output" == "1" ]] && echo '透明接管(高风险)' || echo '默认直连 + 显式代理 127.0.0.1:7890')"
  echo "新的旁路由入口: ${next_ingress_ifaces}"
  echo "新的 DNS 劫持入口: ${next_dns_ifaces}"
  [[ -n "$next_lan_cidrs" ]] && echo "新的局域网网段: ${next_lan_cidrs}"

  render_config
  restart_service_if_active
  ok "旁路由参数已更新"
}
show_secret_command() {
  require_root
  local secret
  secret="$(current_secret)"
  [[ -n "$secret" ]] || die "当前没有可用的控制面密钥"
  printf '%s\n' "$secret"
}
show_status() {
  require_root
  load_settings_readonly
  load_router_env_readonly
  local version="未安装"
  local service_state="inactive"
  local service_enable="disabled"
  local enabled_nodes total_nodes controller_url counts next_step
  [[ -x "$MIHOMO_BIN" ]] && version="$("$MIHOMO_BIN" -v 2>/dev/null | head -n 1 || echo "$MIHOMO_BIN")"
  service_is_active && service_state="active"
  service_is_enabled && service_enable="enabled"
  counts="$(readonly_node_counts)"
  enabled_nodes="${counts%%$'\t'*}"
  total_nodes="${counts##*$'\t'}"
  secret="$(current_secret)"
  controller_scope_summary
  controller_url="http://${CONTROLLER_HOST}:${CONTROLLER_PORT}/ui/"
  echo
  echo "Mihomo 管理器 v${SCRIPT_VERSION}"
  echo "核心版本: ${version}"
  echo "服务状态: ${service_state}"
  echo "开机自启: ${service_enable}"
  echo "当前模式: $(current_mode || echo rule)"
  echo "节点: 启用 ${enabled_nodes} / 总计 ${total_nodes}"
  echo "WebUI: ${controller_url}"
  echo "控制面范围: ${CONTROLLER_SCOPE}"
  echo "控制面密钥: 已隐藏；如需查看执行: mihomo show-secret"
  echo "Mixed/TProxy/DNS: ${MIXED_PORT}/${TPROXY_PORT}/${DNS_PORT}"
  echo "局域网旁路由入口: ${PROXY_INGRESS_INTERFACES}"
  echo "局域网网段: ${LAN_CIDRS:-未设置}"
  echo "DNS 劫持入口: $([[ "${DNS_HIJACK_ENABLED}" == "1" ]] && echo "${DNS_HIJACK_INTERFACES}" || echo '关闭')"
  echo "宿主机流量: $([[ "$PROXY_HOST_OUTPUT" == "1" ]] && echo '透明接管(高风险)' || echo "默认直连；按需显式代理 http://127.0.0.1:${MIXED_PORT}")"
  echo "容器直连名单: ${BYPASS_CONTAINER_NAMES:-无}"
  if [[ "$enabled_nodes" == "0" ]]; then
    next_step="导入并启用节点: mihomo import-links"
  elif [[ "$service_state" != "active" ]]; then
    next_step="启动服务: mihomo start"
  elif [[ -z "${PROXY_INGRESS_INTERFACES:-}" ]]; then
    next_step="配置局域网旁路由入口: mihomo router-wizard"
  else
    next_step="宿主机默认直连；局域网设备把网关和 DNS 指向 NAS 后即可走旁路由"
  fi
  echo "推荐下一步: ${next_step}"
  if [[ "$CONTROLLER_SCOPE" != "仅宿主机" ]]; then
    warn "控制面当前已开放到局域网；这不符合宿主机旁路由的默认安全边界。"
    warn "更推荐把 CONTROLLER_BIND_ADDRESS 保持为 127.0.0.1，只在宿主机本地访问 WebUI。"
  fi
  if [[ "$PROXY_HOST_OUTPUT" == "1" ]]; then
    warn "当前已接管宿主机外连；这可能影响 tailscaled、cloudflared、SSH 反向隧道等守护进程。"
    warn "更推荐保持 0，并让宿主机按需显式走 127.0.0.1:${MIXED_PORT}。"
  fi
  echo "定时重启: ${RESTART_INTERVAL_HOURS:-0}h"
  echo "Alpha 自动更新: $([[ "${ALPHA_AUTO_UPDATE:-0}" == "1" ]] && echo "${ALPHA_UPDATE_ONCALENDAR}" || echo '关闭')"
}

prepare_runtime_assets() {
  require_root
  ensure_layout
  ensure_permissions
  load_settings
  ensure_enabled_nodes
  if [[ ! -x "$MIHOMO_BIN" ]]; then
    install_binary "${CORE_CHANNEL:-alpha}"
  fi
  render_config
  write_service
  write_sysctl
  [[ -f "$COUNTRY_MMDB" ]] || install_country_mmdb
  ensure_geosite_ready
  config_test
}

start_service_command() {
  prepare_runtime_assets
  systemctl_cmd start mihomo
  ok "mihomo 已启动"
}

restart_service_command() {
  prepare_runtime_assets
  systemctl_cmd restart mihomo
  ok "mihomo 已重启"
}

enable_service_command() {
  require_root
  ensure_enabled_nodes
  systemctl_cmd enable mihomo
  ok "已启用开机自启"
}

enable_and_start_service_command() {
  prepare_runtime_assets
  systemctl_cmd enable --now mihomo
  ok "mihomo 已启动并设为开机自启"
}

stop_service_command() {
  require_root
  systemctl_cmd stop mihomo
  ok "mihomo 已停止"
}

service_menu() {
  echo
  echo "1) 启动服务"
  echo "2) 重启服务"
  echo "3) 停止服务"
  echo "4) 启动并设为开机自启"
  echo "5) 仅启用开机自启"
  echo "6) 关闭开机自启"
  echo "7) 查看状态"
  echo "8) 查看最近日志"
  read -rp "选择 [1-8]: " action
  case "$action" in
    1) start_service_command ;;
    2) restart_service_command ;;
    3) stop_service_command ;;
    4) enable_and_start_service_command ;;
    5) enable_service_command ;;
    6) systemctl_cmd disable mihomo ;;
    7) show_status ;;
    8) journalctl_cmd -u mihomo -n 80 --no-pager ;;
    *) warn "无效选择" ;;
  esac
}

